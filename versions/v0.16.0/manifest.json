      },
      "version": "",
      "Uid": null,
      "IsMRef": true,
      "Title": "Wolfgang.Etl.Abstractions.ExtractorBase<TSource, TProgress>",
      "Summary": "<p sourcefile=\"api/Wolfgang.Etl.Abstractions.ExtractorBase-2.yml\" sourcestartlinenumber=\"1\">Provides a basic implementation for data extractors that extract data of type TSource.\nLibrary authors can use this base class to create custom extractors by inheriting from it and implementing\nExtractWorkerAsync and CreateProgressReport methods.</p>\n"
    },
    {
      "type": "ManagedReference",
