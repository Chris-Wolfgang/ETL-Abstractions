<?xml version="1.0" encoding="utf-8"?>
<!--
  Coverlet run settings for Wolfgang.Etl.Abstractions.

  netstandard2.0 and netstandard2.1 assemblies are excluded from coverage.
  No test project targets these TFMs, so every branch in their builds would
  show as uncovered and skew the aggregate numbers.  The #else fallback paths
  they contain exist purely for TFM compatibility and are exercised indirectly
  by the older .NET Framework and netcoreapp3.1 test runs.
-->
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <!-- Exclude the netstandard TFM builds by their output-path fragment.
               Coverlet resolves source files relative to the pdb; the obj path
               always contains the TFM name as a directory segment. -->
          <ExcludeByFile>**/bin/**/netstandard*/**/*.cs;**/obj/**/netstandard*/**/*.cs</ExcludeByFile>
          <ExcludeByAttribute>ExcludeFromCodeCoverageAttribute</ExcludeByAttribute>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
